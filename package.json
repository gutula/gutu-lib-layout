{
  "name": "gutu-lib-layout",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/layout build",
    "typecheck": "bun run --cwd framework/libraries/layout typecheck",
    "lint": "bun run --cwd framework/libraries/layout lint",
    "test": "bun run --cwd framework/libraries/layout test",
    "test:unit": "bun run --cwd framework/libraries/layout test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
